# Postgres (must match docker-compose.yml)
POSTGRES_USER=salary_app
POSTGRES_PASSWORD=salary_app_password
POSTGRES_DB=salary_dev

# API (host-side port is 5433 — see docker-compose.yml; the host uses 5432)
DATABASE_URL=postgresql://salary_app:salary_app_password@localhost:5433/salary_dev
DATABASE_URL_TEST=postgresql://salary_app:salary_app_password@localhost:5433/salary_test
JWT_SECRET=dev-only-change-me
JWT_EXPIRES_IN=8h
PORT=4000

# Web
VITE_API_URL=http://localhost:4000/api/v1
